{
  "name": "jord-jd/json-key-value-store",
  "description": "A simple JSON based key value store",
  "type": "library",
  "license": "LGPL-3.0-only",
  "authors": [
    {
      "name": "Jordan Hall",
      "email": "jordan@hall05.co.uk"
    }
  ],
  "require": {
    "php": ">=7.1",
    "ext-zlib": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "php-coveralls/php-coveralls": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "JordJD\\JsonKeyValueStore\\": "./src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JordJD\\JsonKeyValueStore\\Tests\\": "./tests/Unit"
    }
  },
  "replace": {
    "divineomega/json-key-value-store": "self.version"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "4.0-dev"
    }
  }
}
